{
  "_comment": "NMOS quasi-static gate/body capacitance sweep on the coarse DD mesh.",
  "simulation_type": "dc_sweep",
  "mesh_file": "mesh.json",
  "output_csv": "outputs/nmos2d_dd_cv.csv",
  "doping": [
    {
      "region": "body",
      "donors": 0.0,
      "acceptors": 1e+21
    },
    {
      "region": "source_implant",
      "donors": 5e+21,
      "acceptors": 0.0
    },
    {
      "region": "drain_implant",
      "donors": 5e+21,
      "acceptors": 0.0
    }
  ],
  "contacts": [
    {
      "name": "body",
      "bias": 0.0
    },
    {
      "name": "source",
      "bias": 0.0
    },
    {
      "name": "gate",
      "bias": 0.0
    },
    {
      "name": "drain",
      "bias": 0.0
    }
  ],
  "solver": {
    "method": "gummel",
    "max_iter": 80,
    "reltol": 1e-05,
    "abstol": 1e+18,
    "damping_psi": 0.5
  },
  "sweep": {
    "mode": "cv_quasistatic",
    "contact": "gate",
    "start": 0.0,
    "stop": 0.05,
    "step": 0.05,
    "current_contact": "drain",
    "write_vtk": false,
    "terminal_charge": {
      "contact": "gate",
      "regions": [
        "body"
      ],
      "per_meter": true,
      "contact_radius": 0.001
    }
  },
  "regression": {
    "declared_converged": true,
    "dc_sweep": {
      "expected_rows": 2,
      "max_abs_attempted_step": 0.05,
      "max_abs_accepted_step": 0.05,
      "max_retry_count": 0
    }
  }
}
