{
  "_comment": "Low-voltage PMOS-like 2-D drift-diffusion smoke sweep on a coarse all-silicon mesh.",
  "simulation_type": "dc_sweep",
  "mesh_file": "mesh.json",
  "output_csv": "outputs/pmos2d_dd_iv.csv",
  "doping": [
    {
      "region": "body",
      "donors": 1e+21,
      "acceptors": 0.0
    },
    {
      "region": "source_implant",
      "donors": 0.0,
      "acceptors": 5e+21
    },
    {
      "region": "drain_implant",
      "donors": 0.0,
      "acceptors": 5e+21
    }
  ],
  "contacts": [
    {
      "name": "body",
      "bias": 0.0
    },
    {
      "name": "source",
      "bias": 0.0
    },
    {
      "name": "gate",
      "bias": -0.05
    },
    {
      "name": "drain",
      "bias": 0.0
    }
  ],
  "solver": {
    "method": "gummel",
    "max_iter": 80,
    "reltol": 1e-05,
    "abstol": 1e+18,
    "damping_psi": 0.5
  },
  "sweep": {
    "contact": "drain",
    "start": 0.0,
    "stop": -0.1,
    "step": -0.05,
    "current_contact": "drain",
    "write_vtk": true,
    "vtk_prefix": "outputs/pmos2d_dd_sweep"
  },
  "regression": {
    "declared_converged": true,
    "dc_sweep": {
      "expected_rows": 3,
      "max_abs_attempted_step": 0.05,
      "max_abs_accepted_step": 0.05,
      "max_retry_count": 0,
      "min_converged_rows": 3,
      "require_monotone_abs_current": true
    },
    "mos": {
      "device": "pmos",
      "drain_current_sign": 1.0,
      "idvg": {
        "drain_bias": -0.1,
        "gate_start": 0.0,
        "gate_stop": -0.05,
        "gate_step": -0.05,
        "output_csv": "outputs/pmos2d_dd_idvg.csv"
      }
    }
  }
}
