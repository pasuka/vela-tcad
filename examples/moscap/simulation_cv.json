{
  "_comment": "Prototype MOSCAP interface-charge trend deck: run as dc_sweep to smoke quasi-static CV plumbing with fixed-occupancy traps.",
  "simulation_type": "dc_sweep",
  "mesh_file": "mesh.json",
  "output_csv": "outputs/moscap_cv.csv",
  "doping": [
    { "region": "silicon", "donors": 0.0, "acceptors": 1.0e21 },
    { "region": "oxide", "donors": 0.0, "acceptors": 0.0 }
  ],
  "interfaces": [
    {
      "regions": ["silicon", "oxide"],
      "fixed_charge_m2": 1.0e14,
      "trap_density_m2": 2.0e14,
      "trap_occupancy": 0.5
    }
  ],
  "contacts": [
    { "name": "gate", "type": "metal_gate", "bias": 0.0, "flatband_voltage": 0.0 },
    { "name": "body", "type": "ohmic", "bias": 0.0 }
  ],
  "solver": {
    "method": "gummel",
    "max_iter": 50,
    "reltol": 1e-5,
    "abstol": 1e18,
    "damping_psi": 0.5
  },
  "sweep": {
    "mode": "cv_quasistatic",
    "contact": "gate",
    "start": 0.0,
    "stop": 0.1,
    "step": 0.05,
    "current_contact": "body",
    "write_vtk": false,
    "terminal_charge": {
      "contact": "gate",
      "regions": ["silicon"],
      "per_meter": true,
      "contact_radius": 1e-6
    }
  },
  "regression": {
    "declared_converged": true,
    "dc_sweep": {
      "expected_rows": 3,
      "min_converged_rows": 3,
      "min_nonzero_capacitance_rows": 1
    }
  }
}
