{
  "_comment": "Single-bias PN diode drift-diffusion solve through the coupled Newton CLI path.",
  "simulation_type": "newton",
  "mesh_file": "mesh.json",
  "doping": [
    {
      "region": "n_region",
      "donors": 1e+23,
      "acceptors": 0.0
    },
    {
      "region": "p_region",
      "donors": 0.0,
      "acceptors": 1e+23
    }
  ],
  "contacts": [
    {
      "name": "anode",
      "bias": 0.0
    },
    {
      "name": "cathode",
      "bias": 0.0
    }
  ],
  "solver": {
    "method": "newton",
    "max_iter": 10,
    "reltol": 1e-08,
    "abstol": 1e-18,
    "damping_factor": 1.0,
    "line_search": true,
    "warm_start": false,
    "verbose": false
  }
}
