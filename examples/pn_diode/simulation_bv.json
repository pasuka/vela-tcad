{
  "_comment": "PN diode reverse-bias breakdown-oriented sweep; reports max electric field and current jump diagnostics.",
  "simulation_type": "dc_sweep",
  "mesh_file": "mesh.json",
  "output_csv": "outputs/pn_bv.csv",
  "doping": [
    {
      "region": "n_region",
      "donors": 1e+23,
      "acceptors": 0.0
    },
    {
      "region": "p_region",
      "donors": 0.0,
      "acceptors": 1e+23
    }
  ],
  "contacts": [
    {
      "name": "anode",
      "bias": 0.0
    },
    {
      "name": "cathode",
      "bias": 0.0
    }
  ],
  "solver": {
    "method": "gummel",
    "max_iter": 80,
    "reltol": 1e-05,
    "abstol": 0.0,
    "damping_psi": 0.5
  },
  "sweep": {
    "mode": "bv_reverse",
    "contact": "anode",
    "start": 0.0,
    "stop": -0.5,
    "step": -0.25,
    "current_contact": "anode",
    "write_vtk": true,
    "vtk_prefix": "outputs/pn_bv_sweep",
    "breakdown": {
      "max_electric_field_V_per_m": 50000000.0,
      "current_jump_ratio": 100.0,
      "non_convergence": true
    }
  },
  "regression": {
    "declared_converged": true,
    "dc_sweep": {
      "expected_rows": 3,
      "max_abs_attempted_step": 0.25,
      "max_abs_accepted_step": 0.25,
      "max_retry_count": 0
    }
  }
}
