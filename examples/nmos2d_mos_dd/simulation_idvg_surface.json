{
  "_comment": "NMOS MOS DD Id-Vg smoke sweep with prototype Si/SiO2 surface mobility degradation; not calibrated.",
  "simulation_type": "dc_sweep",
  "mesh_file": "mesh.json",
  "output_csv": "outputs/nmos2d_mos_dd_idvg_surface.csv",
  "doping": [
    {
      "region": "p_body",
      "donors": 0.0,
      "acceptors": 1e+21
    },
    {
      "region": "n_source",
      "donors": 5e+21,
      "acceptors": 0.0
    },
    {
      "region": "n_drain",
      "donors": 5e+21,
      "acceptors": 0.0
    },
    {
      "region": "gate_oxide",
      "donors": 0.0,
      "acceptors": 0.0
    }
  ],
  "interfaces": [
    {
      "regions": [
        "p_body",
        "gate_oxide"
      ],
      "fixed_charge_m2": 100000000000000.0
    }
  ],
  "contacts": [
    {
      "name": "body",
      "type": "ohmic",
      "bias": 0.0
    },
    {
      "name": "source",
      "type": "ohmic",
      "bias": 0.0
    },
    {
      "name": "gate",
      "type": "metal_gate",
      "bias": 0.0,
      "flatband_voltage": 0.0
    },
    {
      "name": "drain",
      "type": "ohmic",
      "bias": 0.1
    }
  ],
  "solver": {
    "method": "gummel",
    "max_iter": 100,
    "reltol": 1e-05,
    "abstol": 1e+18,
    "damping_psi": 0.5,
    "mobility": {
      "model": "caughey_thomas_field_surface",
      "surface": {
        "theta_electron_m_per_V": 2e-08,
        "theta_hole_m_per_V": 1e-08,
        "beta": 1.0,
        "reference_field_V_per_m": 0.0,
        "min_factor": 0.05,
        "surface_region": "p_body",
        "surface_interface": [
          "p_body",
          "gate_oxide"
        ]
      }
    }
  },
  "sweep": {
    "mode": "iv",
    "contact": "gate",
    "start": 0.0,
    "stop": 0.1,
    "step": 0.05,
    "current_contact": "drain",
    "write_vtk": false
  },
  "regression": {
    "declared_converged": true,
    "dc_sweep": {
      "expected_rows": 3,
      "max_abs_attempted_step": 0.05,
      "max_abs_accepted_step": 0.05,
      "max_retry_count": 0,
      "min_converged_rows": 3,
      "require_monotone_abs_current": true
    },
    "surface_mobility": {
      "baseline_config": "simulation_idvg.json",
      "surface_csv": "outputs/nmos2d_mos_dd_idvg_surface.csv",
      "baseline_csv": "outputs/nmos2d_mos_dd_idvg_surface_baseline.csv",
      "current_ratio_tolerance": 1.01
    }
  }
}
