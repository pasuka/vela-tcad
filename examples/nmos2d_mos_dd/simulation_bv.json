{
  "_comment": "Mixed-material Si/SiO2 NMOS off-state drain reverse/high-field diagnostic smoke sweep; not calibrated BV.",
  "simulation_type": "dc_sweep",
  "mesh_file": "mesh.json",
  "output_csv": "outputs/nmos2d_mos_dd_bv.csv",
  "doping": [
    { "region": "p_body", "donors": 0.0, "acceptors": 1e+21 },
    { "region": "n_source", "donors": 5e+21, "acceptors": 0.0 },
    { "region": "n_drain", "donors": 5e+21, "acceptors": 0.0 },
    { "region": "gate_oxide", "donors": 0.0, "acceptors": 0.0 }
  ],
  "contacts": [
    { "name": "body", "type": "ohmic", "bias": 0.0 },
    { "name": "source", "type": "ohmic", "bias": 0.0 },
    { "name": "gate", "type": "metal_gate", "bias": 0.0, "flatband_voltage": 0.0 },
    { "name": "drain", "type": "ohmic", "bias": 0.0 }
  ],
  "solver": {
    "method": "gummel",
    "max_iter": 100,
    "reltol": 1e-05,
    "abstol": 1e+18,
    "damping_psi": 0.5,
    "impact_ionization": { "model": "none" }
  },
  "sweep": {
    "mode": "bv_reverse",
    "contact": "drain",
    "start": 0.0,
    "stop": 0.2,
    "step": 0.1,
    "current_contact": "drain",
    "write_vtk": false,
    "breakdown": {
      "max_electric_field_V_per_m": 5e8,
      "current_jump_ratio": 1e6,
      "non_convergence": false
    }
  },
  "regression": {
    "declared_converged": true,
    "dc_sweep": {
      "expected_rows": 3,
      "max_abs_attempted_step": 0.1,
      "max_abs_accepted_step": 0.1,
      "max_retry_count": 0,
      "min_converged_rows": 3,
      "require_monotone_abs_current": true,
      "require_monotone_max_field": true,
      "min_max_electric_field_V_per_m": 1e5,
      "max_max_electric_field_V_per_m": 1e9
    }
  }
}
