{
  "_comment": "Mixed-material Si/SiO2 NMOS DD prototype Id-Vd smoke sweep; CI coarse and not calibrated.",
  "simulation_type": "dc_sweep",
  "mesh_file": "mesh.json",
  "output_csv": "outputs/nmos2d_mos_dd_iv.csv",
  "doping": [
    { "region": "p_body", "donors": 0.0, "acceptors": 1e+21 },
    { "region": "n_source", "donors": 5e+21, "acceptors": 0.0 },
    { "region": "n_drain", "donors": 5e+21, "acceptors": 0.0 },
    { "region": "gate_oxide", "donors": 0.0, "acceptors": 0.0 }
  ],
  "contacts": [
    { "name": "body", "type": "ohmic", "bias": 0.0 },
    { "name": "source", "type": "ohmic", "bias": 0.0 },
    { "name": "gate", "type": "metal_gate", "bias": 0.1, "flatband_voltage": 0.0 },
    { "name": "drain", "type": "ohmic", "bias": 0.0 }
  ],
  "solver": {
    "method": "gummel",
    "max_iter": 100,
    "reltol": 1e-05,
    "abstol": 1e+18,
    "damping_psi": 0.5
  },
  "sweep": {
    "mode": "iv",
    "contact": "drain",
    "start": 0.0,
    "stop": 0.1,
    "step": 0.05,
    "current_contact": "drain",
    "write_vtk": true,
    "vtk_prefix": "outputs/nmos2d_mos_dd_iv_sweep"
  },
  "regression": {
    "declared_converged": true,
    "dc_sweep": {
      "expected_rows": 3,
      "max_abs_attempted_step": 0.05,
      "max_abs_accepted_step": 0.05,
      "max_retry_count": 0,
      "min_converged_rows": 3,
      "require_monotone_abs_current": true
    },
    "mos": {
      "device": "nmos",
      "drain_current_sign": 1.0,
      "idvg": {
        "drain_bias": 0.1,
        "gate_start": 0.0,
        "gate_stop": 0.1,
        "gate_step": 0.05,
        "output_csv": "outputs/nmos2d_mos_dd_idvg_from_iv.csv"
      }
    }
  }
}
