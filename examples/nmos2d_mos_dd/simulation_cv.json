{
  "_comment": "Mixed-material Si/SiO2 NMOS prototype quasi-static gate capacitance smoke sweep; not calibrated.",
  "simulation_type": "dc_sweep",
  "mesh_file": "mesh.json",
  "output_csv": "outputs/nmos2d_mos_dd_cv.csv",
  "doping": [
    { "region": "p_body", "donors": 0.0, "acceptors": 1e+21 },
    { "region": "n_source", "donors": 5e+21, "acceptors": 0.0 },
    { "region": "n_drain", "donors": 5e+21, "acceptors": 0.0 },
    { "region": "gate_oxide", "donors": 0.0, "acceptors": 0.0 }
  ],
  "interfaces": [
    { "regions": ["p_body", "gate_oxide"], "trap_density_m2": 2.0e14, "trap_occupancy": 0.5 }
  ],
  "contacts": [
    { "name": "body", "type": "ohmic", "bias": 0.0 },
    { "name": "source", "type": "ohmic", "bias": 0.0 },
    { "name": "gate", "type": "metal_gate", "bias": 0.0, "flatband_voltage": 0.0 },
    { "name": "drain", "type": "ohmic", "bias": 0.0 }
  ],
  "solver": {
    "method": "gummel",
    "max_iter": 100,
    "reltol": 1e-05,
    "abstol": 1e+18,
    "damping_psi": 0.5
  },
  "sweep": {
    "mode": "cv_quasistatic",
    "contact": "gate",
    "start": 0.0,
    "stop": 0.1,
    "step": 0.05,
    "current_contact": "drain",
    "write_vtk": false,
    "terminal_charge": {
      "contact": "gate",
      "regions": ["p_body", "n_source", "n_drain"],
      "per_meter": true,
      "contact_radius": 1e-6
    }
  },
  "regression": {
    "declared_converged": true,
    "dc_sweep": {
      "expected_rows": 3,
      "max_abs_attempted_step": 0.05,
      "max_abs_accepted_step": 0.05,
      "max_retry_count": 0,
      "min_converged_rows": 3,
      "min_nonzero_capacitance_rows": 1
    }
  }
}
