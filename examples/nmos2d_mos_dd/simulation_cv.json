{
  "_comment": "Mixed-material Si/SiO2 NMOS prototype multi-terminal quasi-static MOS CV prototype smoke sweep; not calibrated.",
  "simulation_type": "dc_sweep",
  "mesh_file": "mesh.json",
  "output_csv": "outputs/nmos2d_mos_dd_cv.csv",
  "doping": [
    {
      "region": "p_body",
      "donors": 0.0,
      "acceptors": 1e+21
    },
    {
      "region": "n_source",
      "donors": 5e+21,
      "acceptors": 0.0
    },
    {
      "region": "n_drain",
      "donors": 5e+21,
      "acceptors": 0.0
    },
    {
      "region": "gate_oxide",
      "donors": 0.0,
      "acceptors": 0.0
    }
  ],
  "interfaces": [
    {
      "regions": [
        "p_body",
        "gate_oxide"
      ],
      "trap_density_m2": 200000000000000.0,
      "trap_occupancy": 0.5
    }
  ],
  "contacts": [
    {
      "name": "body",
      "type": "ohmic",
      "bias": 0.0
    },
    {
      "name": "source",
      "type": "ohmic",
      "bias": 0.0
    },
    {
      "name": "gate",
      "type": "metal_gate",
      "bias": 0.0,
      "flatband_voltage": 0.0
    },
    {
      "name": "drain",
      "type": "ohmic",
      "bias": 0.0
    }
  ],
  "solver": {
    "method": "gummel",
    "max_iter": 100,
    "reltol": 1e-05,
    "abstol": 1e+18,
    "damping_psi": 0.5
  },
  "sweep": {
    "mode": "cv_quasistatic",
    "contact": "gate",
    "start": 0.0,
    "stop": 0.1,
    "step": 0.05,
    "current_contact": "drain",
    "write_vtk": false,
    "terminal_charge": {
      "contact": "gate",
      "regions": [
        "p_body",
        "n_source",
        "n_drain"
      ],
      "per_meter": true,
      "contact_radius": 1e-06
    },
    "terminal_charges": [
      {
        "name": "gate",
        "contact": "gate",
        "regions": [
          "p_body",
          "n_source",
          "n_drain"
        ],
        "per_meter": true,
        "contact_radius": 1e-06
      },
      {
        "name": "drain",
        "contact": "drain",
        "regions": [
          "n_drain"
        ],
        "per_meter": true,
        "contact_radius": 1e-06
      },
      {
        "name": "source",
        "contact": "source",
        "regions": [
          "n_source"
        ],
        "per_meter": true,
        "contact_radius": 1e-06
      },
      {
        "name": "body",
        "contact": "body",
        "regions": [
          "p_body"
        ],
        "per_meter": true,
        "contact_radius": 1e-06
      }
    ]
  },
  "regression": {
    "declared_converged": true,
    "dc_sweep": {
      "expected_rows": 3,
      "max_abs_attempted_step": 0.05,
      "max_abs_accepted_step": 0.05,
      "max_retry_count": 0,
      "min_converged_rows": 3,
      "min_nonzero_capacitance_rows": 1,
      "min_nonzero_Cgg_rows": 1
    }
  }
}
