{
  "_comment": "Schottky diode IV smoke test. Prototype Dirichlet-barrier contact, not a calibrated thermionic-emission model. Forward bias drives the diode into low forward-current operation; the reverse-bias point shows the saturation-like floor produced by the barrier-based carrier density boundary.",
  "simulation_type": "dc_sweep",
  "mesh_file": "mesh.json",
  "output_csv": "outputs/schottky_iv.csv",
  "doping": [
    {
      "region": "n_silicon",
      "donors": 1e+22,
      "acceptors": 0.0
    }
  ],
  "contacts": [
    {
      "name": "anode",
      "type": "schottky",
      "bias": 0.0,
      "barrier_eV": 0.6,
      "surface_recombination_velocity_m_per_s": 1.0e5,
      "emission_model": "dirichlet_barrier"
    },
    {
      "name": "cathode",
      "type": "ohmic",
      "bias": 0.0
    }
  ],
  "solver": {
    "method": "gummel",
    "max_iter": 100,
    "reltol": 1e-05,
    "abstol": 0.0,
    "damping_psi": 0.5,
    "temperature_K": 300.0
  },
  "sweep": {
    "contact": "anode",
    "start": -0.1,
    "stop": 0.3,
    "step": 0.1,
    "current_contact": "anode",
    "write_vtk": true,
    "vtk_prefix": "outputs/schottky_sweep"
  },
  "validation": {
    "carrier_floor": 1.0,
    "check_contact_quasi_fermi_bias": false
  },
  "regression": {
    "declared_converged": true,
    "dc_sweep": {
      "expected_rows": 5,
      "max_abs_attempted_step": 0.1,
      "max_abs_accepted_step": 0.1,
      "max_retry_count": 0,
      "min_converged_rows": 5
    }
  }
}
