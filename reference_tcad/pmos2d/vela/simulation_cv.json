{
  "_comment": "PMOS mixed Si/SiO2 unit_scaling multi-terminal quasi-static CV reference smoke sweep.",
  "simulation_type": "dc_sweep",
  "mesh_file": "mesh.json",
  "output_csv": "pmos2d_cv.csv",
  "scaling": {
    "mode": "unit_scaling"
  },
  "doping": [
    { "region": "n_body", "donors": 1.0e15, "acceptors": 0.0 },
    { "region": "p_source", "donors": 0.0, "acceptors": 5.0e15 },
    { "region": "p_drain", "donors": 0.0, "acceptors": 5.0e15 },
    { "region": "gate_oxide", "donors": 0.0, "acceptors": 0.0 }
  ],
  "interfaces": [
    { "regions": ["n_body", "gate_oxide"], "trap_density_m2": 2.0e10, "trap_occupancy": 0.5 }
  ],
  "contacts": [
    { "name": "body", "type": "ohmic", "bias": 0.0 },
    { "name": "source", "type": "ohmic", "bias": 0.0 },
    { "name": "gate", "type": "metal_gate", "bias": 0.0, "flatband_voltage": 0.0 },
    { "name": "drain", "type": "ohmic", "bias": 0.0 }
  ],
  "solver": {
    "method": "gummel",
    "max_iter": 100,
    "reltol": 1.0e-5,
    "abstol": 1.0e18,
    "damping_psi": 0.5
  },
  "sweep": {
    "mode": "cv_quasistatic",
    "contact": "gate",
    "start": 0.0,
    "stop": -0.1,
    "step": -0.05,
    "current_contact": "drain",
    "write_vtk": false,
    "terminal_charge": {
      "contact": "gate",
      "regions": ["n_body", "p_source", "p_drain"],
      "per_meter": true,
      "contact_radius": 1.0
    },
    "terminal_charges": [
      { "name": "gate", "contact": "gate", "regions": ["n_body", "p_source", "p_drain"], "per_meter": true, "contact_radius": 1.0 },
      { "name": "drain", "contact": "drain", "regions": ["p_drain"], "per_meter": true, "contact_radius": 1.0 },
      { "name": "source", "contact": "source", "regions": ["p_source"], "per_meter": true, "contact_radius": 1.0 },
      { "name": "body", "contact": "body", "regions": ["n_body"], "per_meter": true, "contact_radius": 1.0 }
    ]
  }
}
