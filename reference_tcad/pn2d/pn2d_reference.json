{
  "case": "pn2d",
  "device": "pn_diode",
  "mesh_tdr": "pn2d_msh.tdr",
  "sde_cmd": "pn2d_sde.cmd",
  "tdr_doping": {
    "compensated_node_policy": "dominant_signed_region"
  },
  "vela_solver": {
    "method": "gummel_newton",
    "max_iter": 30,
    "reltol": 1.0e-6,
    "abstol": 1.0e-18,
    "damping_psi": 0.2,
    "damping_factor": 1.0,
    "max_update": 5.0,
    "line_search": true,
    "warm_start": true,
    "contact_boundary_reconstruction": "dominant_signed_contact_mean",
    "verbose": false,
    "handoff": {
      "fallback": "none",
      "require_gummel_convergence": false,
      "gummel_max_iter": 0,
      "newton_max_iter": 30
    }
  },
  "simulations": [
    {
      "name": "iv",
      "kind": "iv",
      "tdr": "pn2d_des.tdr",
      "cmd": "pn2d_sdevice.cmd",
      "plt": "pn2d_iv.plt",
      "bias_column": "Anode OuterVoltage",
      "current_column": "Anode TotalCurrent",
      "vela_current_contact": "Cathode",
      "vela_stop": 0.3,
      "vela_step": 0.1,
      "comparison_min_points": 10,
      "require_trend_match": false,
      "vela_solver": {
        "mobility": {
          "model": "caughey_thomas_field"
        }
      },
      "comparison": {
        "candidate_scale": -1.0,
        "candidate_column": "current_total_A_per_um",
        "bias_min": 0.2,
        "bias_max": 0.3,
        "max_orders_of_magnitude": 1.0,
        "require_trend_match": true,
        "min_points": 2
      },
      "runtime_diagnostic": {
        "enabled": false,
        "doping_scale": 0.0001,
        "step": 0.1
      }
    },
    {
      "name": "bv",
      "kind": "bv",
      "tdr": "pn2d_bv_des.tdr",
      "cmd": "pn2d_bv_sdevice.cmd",
      "plt": "pn2d_bv.plt",
      "bias_column": "Cathode OuterVoltage",
      "current_column": "Cathode TotalCurrent",
      "vela_stop": 0.05,
      "vela_step": 0.05,
      "comparison_kind": "iv",
      "vela_solver": {
        "mobility": {
          "model": "caughey_thomas",
          "electron_mu_min_m2_V_s": 46.458,
          "hole_mu_min_m2_V_s": 39.961,
          "electron_nref_m3": 9.68e16,
          "hole_nref_m3": 2.23e17,
          "electron_alpha": 0.6052,
          "hole_alpha": 0.623
        },
        "bandgap_narrowing": "none",
        "recombination": [
          "srh"
        ],
        "taun": 1.0e-6,
        "taup": 1.0e-6,
        "impact_ionization": {
          "model": "none"
        }
      },
      "require_trend_match": false,
      "comparison": {
        "candidate_scale": 1.0,
        "candidate_column": "current_total_A_per_um",
        "bias_min": 0.05,
        "bias_max": 0.05,
        "max_orders_of_magnitude": 1.0,
        "require_trend_match": false,
        "min_points": 1
      },
      "runtime_diagnostic": {
        "enabled": false,
        "doping_scale": 0.0001,
        "step": 5.0
      }
    }
  ]
}
