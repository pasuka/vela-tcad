{
  "case": "pn2d",
  "device": "pn_diode",
  "mesh_tdr": "pn2d_msh.tdr",
  "sde_cmd": "pn2d_sde.cmd",
  "vela_solver": {
    "method": "gummel_newton",
    "max_iter": 5,
    "reltol": 1.0e-8,
    "abstol": 1.0e-18,
    "damping_psi": 0.25,
    "damping_factor": 1.0,
    "line_search": true,
    "warm_start": true,
    "verbose": false,
    "handoff": {
      "fallback": "gummel_on_newton_failure",
      "require_gummel_convergence": false,
      "newton_max_iter": 0
    }
  },
  "simulations": [
    {
      "name": "iv",
      "kind": "iv",
      "tdr": "pn2d_des.tdr",
      "cmd": "pn2d_sdevice.cmd",
      "plt": "pn2d_iv.plt",
      "bias_column": "Anode OuterVoltage",
      "current_column": "Anode TotalCurrent",
      "vela_step": 0.1,
      "comparison_min_points": 10,
      "require_trend_match": false,
      "runtime_diagnostic": {
        "enabled": false,
        "doping_scale": 0.0001,
        "step": 0.1
      }
    },
    {
      "name": "bv",
      "kind": "bv",
      "tdr": "pn2d_bv_des.tdr",
      "cmd": "pn2d_bv_sdevice.cmd",
      "plt": "pn2d_bv.plt",
      "bias_column": "Cathode OuterVoltage",
      "current_column": "Cathode TotalCurrent",
      "vela_step": 5.0,
      "comparison_kind": "iv",
      "require_trend_match": false,
      "runtime_diagnostic": {
        "enabled": false,
        "doping_scale": 0.0001,
        "step": 5.0
      }
    }
  ]
}
