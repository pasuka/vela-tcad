{
  "_comment": "NMOS mixed Si/SiO2 unit_scaling off-state drain high-field diagnostic; trend/order only.",
  "simulation_type": "dc_sweep",
  "mesh_file": "mesh.json",
  "output_csv": "nmos2d_bv.csv",
  "scaling": {
    "mode": "unit_scaling"
  },
  "doping": [
    { "region": "p_body", "donors": 0.0, "acceptors": 1.0e15 },
    { "region": "n_source", "donors": 5.0e15, "acceptors": 0.0 },
    { "region": "n_drain", "donors": 5.0e15, "acceptors": 0.0 },
    { "region": "gate_oxide", "donors": 0.0, "acceptors": 0.0 }
  ],
  "contacts": [
    { "name": "body", "type": "ohmic", "bias": 0.0 },
    { "name": "source", "type": "ohmic", "bias": 0.0 },
    { "name": "gate", "type": "metal_gate", "bias": 0.0, "flatband_voltage": 0.0 },
    { "name": "drain", "type": "ohmic", "bias": 0.0 }
  ],
  "solver": {
    "method": "gummel",
    "max_iter": 100,
    "reltol": 1.0e-5,
    "abstol": 1.0e18,
    "damping_psi": 0.5,
    "impact_ionization": { "model": "none" }
  },
  "sweep": {
    "mode": "bv_reverse",
    "contact": "drain",
    "start": 0.0,
    "stop": 0.2,
    "step": 0.1,
    "current_contact": "drain",
    "write_vtk": false,
    "breakdown": {
      "max_electric_field_V_per_m": 5.0e6,
      "current_jump_ratio": 1.0e6,
      "non_convergence": false
    }
  }
}
